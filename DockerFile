# ==========================================
# STAGE 1: Download & Extract Node.js
# ==========================================
FROM mcr.microsoft.com/windows/servercore:ltsc2019 AS builder

WORKDIR C:\downloads

RUN powershell -Command \
    $ErrorActionPreference = 'Stop'; \
    Invoke-WebRequest -Uri https://nodejs.org/dist/v20.11.0/node-v20.11.0-win-x64.zip -OutFile node.zip; \
    Expand-Archive node.zip -DestinationPath C:\; \
    Rename-Item C:\node-v20.11.0-win-x64 C:\node

# ==========================================
# STAGE 2: Nano Server 1809 Final Image  (1809 is equivilent of 2019 and suitable for its kernal)
# ==========================================
FROM mcr.microsoft.com/windows/nanoserver:1809

WORKDIR C:\app

# Copy Node.js from the builder stage
COPY --from=builder C:\node C:\node

# Copy your local app file
COPY app.js .

# Add Node to the path
ENV PATH="C:\node;${PATH}"

# Run the app
CMD ["node", "app.js"]
